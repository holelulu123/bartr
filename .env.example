# =============================================================================
# bartr — Environment Variables
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# DEV DEFAULTS: Values below work out-of-the-box for local dev (docker-compose).
# PRODUCTION:   Generate real secrets with: bash scripts/generate-secrets.sh
#               Lines marked [CHANGE IN PROD] MUST be replaced before deploying.
# =============================================================================

# --- Runtime Mode ---
# Set to "production" for deployed environments (enables strict secret checks)
NODE_ENV=development

# --- PostgreSQL ---
POSTGRES_USER=bartr
POSTGRES_PASSWORD=bartr_dev_password            # [CHANGE IN PROD]
POSTGRES_DB=bartr
DATABASE_URL=postgresql://bartr:bartr_dev_password@postgres:5432/bartr  # [CHANGE IN PROD]

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=bartr
MINIO_ROOT_PASSWORD=bartr_dev_password           # [CHANGE IN PROD]
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=listing-images

# --- API Server ---
API_PORT=4000
API_HOST=0.0.0.0

# --- Auth / JWT ---
JWT_SECRET=change-me-in-production               # [CHANGE IN PROD] — min 32 chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
CLIENT_URL=http://localhost

# --- Encryption (AES-256-GCM for emails, messages) ---
# 64-character hex string (32 bytes). Generate with: openssl rand -hex 32
# Leave blank for dev (a deterministic fallback is used). Required in production.
ENCRYPTION_KEY=

# --- Next.js ---
NEXT_PUBLIC_API_URL=http://localhost/api

# --- Health Dashboard Auth (HTTP Basic Auth) ---
# Protects /health endpoints with password. Leave HEALTH_PASSWORD_HASH blank to disable in dev.
# Generate hash:  node -e "import('argon2').then(a => a.hash('your-password')).then(console.log)"
HEALTH_USERNAME=admin
HEALTH_PASSWORD=                                     # [PLAINTEXT — used by web proxy only]
HEALTH_PASSWORD_HASH=                                # [ARGON2 HASH — used by API server]

# --- Resend (email verification) — leave blank to disable in dev ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@bartr.app

# --- Donation Addresses ---
# Generate addresses from any wallet (Trust Wallet, MetaMask, etc.)
# Each address accepts the native coin + stablecoins on that network
NEXT_PUBLIC_BTC_ADDRESS=your-btc-address-here
NEXT_PUBLIC_ETH_ADDRESS=your-eth-address-here
NEXT_PUBLIC_SOL_ADDRESS=your-sol-address-here
NEXT_PUBLIC_TRON_ADDRESS=your-tron-address-here
NEXT_PUBLIC_TON_ADDRESS=your-ton-address-here
